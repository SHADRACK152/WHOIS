{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.9.0",
      "includeFiles": "{app,public}/**"
    }
  },
  "routes": [
    { "src": "/assets/(.*)", "dest": "/public/assets/$1" },
    { "src": "/admin/(.*)", "dest": "/public/admin/$1" },
    { "src": "/pages/assets/(.*)", "dest": "/public/assets/$1" },
    { "src": "/pages/(.*)", "dest": "/public/pages/$1" },
    { "src": "/api/(.*)", "dest": "/public/api/$1" },
    { "src": "/", "dest": "/public/index.php" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}